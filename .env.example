# Valravn Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# Anthropic (default provider for most modules)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# OpenRouter (access to many models including Anthropic via their API)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama (for local models)
# Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# PER-MODULE MODEL CONFIGURATION (Optional)
# Format: provider:model_name
# =============================================================================

# Uncomment to override defaults per module:
# VALRAVN_PLAN_MODEL=anthropic:claude-3-5-sonnet-20241022
# VALRAVN_REFLECTOR_MODEL=anthropic:claude-3-5-sonnet-20241022
# VALRAVN_MUTATOR_MODEL=anthropic:claude-3-5-sonnet-20241022
# VALRAVN_ANOMALY_MODEL=anthropic:claude-3-5-sonnet-20241022
# VALRAVN_CONCLUSIONS_MODEL=anthropic:claude-3-5-sonnet-20241022
# VALRAVN_SELF_ASSESS_MODEL=anthropic:claude-3-5-sonnet-20241022
# VALRAVN_TOOL_RUNNER_MODEL=anthropic:claude-3-5-sonnet-20241022

# Examples using different providers:

# OpenAI GPT-4o for faster/cheaper tasks
# VALRAVN_TOOL_RUNNER_MODEL=openai:gpt-4o

# Local Llama model via Ollama (no API costs!)
# VALRAVN_PLAN_MODEL=ollama:llama3.2

# Claude via OpenRouter (if you prefer their pricing)
# VALRAVN_REFLECTOR_MODEL=openrouter:anthropic/claude-3-opus-20240229

# =============================================================================
# MLFLOW CONFIGURATION (Optional)
# =============================================================================

# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=valravn-training

# =============================================================================
# DEBUGGING
# =============================================================================

# Set to DEBUG for verbose LLM logging
# LOG_LEVEL=INFO